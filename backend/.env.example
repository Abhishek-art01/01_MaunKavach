# Copy to .env locally; on Render, set these as actual Environment Variables in the dashboard
# (never commit a real .env file).

# Supabase Postgres connection string — Project Settings → Database → Connection string (URI).
# Use the "Transaction" pooler string for Render's free tier (port 6543) to avoid exhausting
# direct connections.
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...        # server-only secret. NEVER ship this in the Android app.

# Name of the Supabase Storage bucket you create for encrypted file blobs (private bucket).
SUPABASE_STORAGE_BUCKET=vaultchat-encrypted-blobs

# Random long secret for signing session JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_hex_string

# Port Render injects automatically; safe default for local runs.
PORT=8080
