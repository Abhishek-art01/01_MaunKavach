<?xml version="1.0" encoding="utf-8"?>
<!--
  Native certificate pinning, per spec ("Certificate pinning using native network security
  config" — no OkHttp/CertificatePinner needed). Replace the pin with your own server's
  SHA-256 SPKI hash before shipping. Generate with:
    openssl x509 -in server.crt -pubkey -noout |
      openssl pkey -pubin -outform der |
      openssl dgst -sha256 -binary | base64
-->
<network-security-config>
    <domain-config>
        <domain includeSubdomains="true">your-maunkavach-server.example</domain>
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">REPLACE_WITH_REAL_SERVER_SPKI_PIN==</pin>
            <!-- backup pin recommended in production -->
            <pin digest="SHA-256">REPLACE_WITH_BACKUP_SPKI_PIN==</pin>
        </pin-set>
    </domain-config>

    <!-- Block all plaintext HTTP everywhere -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
