<?xml version="1.0" encoding="utf-8"?>
<!--
  Belt-and-suspenders alongside allowBackup="false": explicitly exclude everything from
  cloud backup and device-to-device transfer. Vault Key material must never be backed up.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
